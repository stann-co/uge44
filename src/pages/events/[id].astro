---
import "../../pages/style/generel.css";
import "../../pages/style/layout.css";

const API_URL =
  "https://cbrvuyyzawexiapgwjsy.supabase.co/rest/v1/uge_44_begivenheder?apikey=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNicnZ1eXl6YXdleGlhcGd3anN5Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYzNDY2MzQsImV4cCI6MjA5MTkyMjYzNH0.HdxZ0uTaS1WBOktv6Y_rwMNxeGQLBjeFiUHsyLn1dBs";

export async function getStaticPaths() {
  const response = await fetch(
    "https://cbrvuyyzawexiapgwjsy.supabase.co/rest/v1/uge_44_begivenheder?apikey=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNicnZ1eXl6YXdleGlhcGd3anN5Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYzNDY2MzQsImV4cCI6MjA5MTkyMjYzNH0.HdxZ0uTaS1WBOktv6Y_rwMNxeGQLBjeFiUHsyLn1dBs",
  );
  const events = await response.json();

  return events.map((event) => ({
    params: { id: String(event.id) },
  }));
}

const { id } = Astro.params;

let event = null;
let relatedEvents = [];

try {
  const response = await fetch(API_URL);

  if (!response.ok) {
    throw new Error("Kunne ikke hente events");
  }

  const events = await response.json();

  event = events.find((item) => String(item.id) === String(id)) ?? null;

  if (event) {
    relatedEvents = events
      .filter((item) => item.id !== event.id)
      .filter((item) => item.region === event.region || item.date === event.date)
      .slice(0, 2);
  }
} catch (error) {
  console.error(error);
}

function formatDate(dateString) {
  const date = new Date(dateString);
  return new Intl.DateTimeFormat("da-DK", {
    weekday: "long",
    day: "numeric",
    month: "long",
  }).format(date);
}

function formatTime(timeString) {
  return timeString?.slice(0, 5) ?? "";
}

function formatPrice(price) {
  if (price === 0) return "Gratis";
  return `${price} kr.`;
}

if (!event) {
  throw new Error("Event ikke fundet");
}
---

<html lang="da">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow" />
    <title>{event.name} | UGE44</title>
    <meta name="description" content={event.description} />
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <div class="container header-inner">
          <a href="/" class="logo" aria-label="Gå til forsiden">
            <img src="public/images/u44logov1.svg" alt="UGE44 logo" class="logo-image" width="48" height="48" />
            <span class="logo-text">UGE<span class="logo-accent">44</span></span>
          </a>

          <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="main-nav" aria-label="Åbn menu"> Menu </button>

          <nav id="main-nav" class="main-nav" aria-label="Hovedmenu">
            <a href="/booking">Booking</a>
            <a href="/#om">Om</a>
            <a href="/kalender" class="is-active">Kalender</a>
          </nav>
        </div>
      </header>

      <main class="event-page">
        <section class="event-topbar">
          <div class="container">
            <a href="/kalender" class="event-back">← Kalender</a>
          </div>
        </section>

        <section class="event-single">
          <div class="container event-single-inner">
            <div class="event-single-decor" aria-hidden="true">
              <img src="/images/leaves.png" alt="" />
            </div>

            <h1 class="event-title">{event.name}</h1>

            <div class="event-meta-block">
              <p class="event-date-line">
                {formatDate(event.date)} kl. {formatTime(event.time)}
              </p>
              <p class="event-location-line">{event.address}</p>
            </div>

            <div class="event-image-wrap">
              <img src={event.photo} alt={event.name} class="event-single-image" width="1200" height="800" />
            </div>

            <div class="event-description">
              <p>{event.description}</p>
            </div>

            <div class="event-cta-wrap">
              <a href="/booking" class="btn btn-primary event-signup-btn">Tilmeld</a>
            </div>

            <section class="related-events" aria-labelledby="related-heading">
              <h2 id="related-heading">Relateret</h2>

              <div class="related-grid">
                {
                  relatedEvents.map((item) => (
                    <article class="related-card">
                      <a href={`/events/${item.id}`} class="related-card-link">
                        <h3>{item.name}</h3>
                        <p>
                          {formatDate(item.date)} kl. {formatTime(item.time)}
                        </p>
                      </a>
                    </article>
                  ))
                }
              </div>
            </section>
          </div>
        </section>
      </main>

      <footer class="site-footer">
        <div class="container footer-inner">
          <a href="/" class="logo footer-logo" aria-label="Gå til forsiden">
            <span class="logo-text">UGE<span class="logo-accent">44</span></span>
          </a>

          <nav class="footer-nav" aria-label="Footermenu">
            <a href="/#om">Om kampagnen</a>
            <a href="/booking">Booking</a>
            <a href="/" aria-label="Facebook">Facebook</a>
            <a href="/" aria-label="Instagram">Instagram</a>
          </nav>
        </div>
      </footer>
    </div>

    <script>
      const toggle = document.querySelector(".menu-toggle");
      const nav = document.querySelector("#main-nav");

      if (toggle && nav) {
        toggle.addEventListener("click", () => {
          const isOpen = toggle.getAttribute("aria-expanded") === "true";
          toggle.setAttribute("aria-expanded", String(!isOpen));
          toggle.setAttribute("aria-label", isOpen ? "Åbn menu" : "Luk menu");
          nav.classList.toggle("is-open");
        });
      }
    </script>
  </body>
</html>
